NODE_ENV=production

POSTGRES_DB=schoolhub
POSTGRES_USER=schoolhub
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://schoolhub:change-me@postgres:5432/schoolhub?schema=public
DIRECT_URL=postgresql://schoolhub:change-me@postgres:5432/schoolhub?schema=public

REDIS_URL=redis://redis:6379

JWT_SECRET=generate-with-openssl-rand-base64-64
JWT_ISSUER=schoolhub-ehadir
JWT_AUDIENCE=schoolhub-web
JWT_EXPIRES_IN=15m
SESSION_TTL_MS=28800000
REFRESH_TTL_MS=604800000
WORKER_TOKEN=generate-with-openssl-rand-base64-48
READER_SECRET_ENCRYPTION_KEY=generate-with-openssl-rand-base64-48
READER_SIGNATURE_SKEW_MS=120000
READER_NONCE_TTL_MS=300000
SCHOOL_TIMEZONE=Asia/Jakarta
# Comma-separated Express trust-proxy entries. Direct Docker Compose uses the bundled Nginx reverse-proxy only.
TRUSTED_PROXY_CIDRS=loopback,linklocal,uniquelocal
CORS_ORIGIN=https://ehadir.example.sch.id

# SSO / WorkOS AuthKit (disabled by default; enable only after backend mapping is configured)
SSO_ENABLED=false
WORKOS_CLIENT_ID=
WORKOS_CLIENT_SECRET=
WORKOS_ISSUER=
WORKOS_AUDIENCE=
WORKOS_REDIRECT_URI=
PUBLIC_APP_ORIGIN=https://ehadir.example.sch.id
STEP_UP_FOR_POLICY=true
STEP_UP_FOR_READER_ROTATE=true
MIN_GATE_STAY_MINUTES=10
ANDROID_READER_MIN_SUPPORTED_VERSION_CODE=1
ANDROID_READER_LATEST_VERSION_NAME=1.0.0
ANDROID_READER_LATEST_VERSION_CODE=1

ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_USERNAME=admin.tu
ADMIN_PASSWORD=generate-unique-bootstrap-password-do-not-reuse
ADMIN_FULL_NAME=Admin TU
DEFAULT_USER_PASSWORD=generate-unique-temporary-password-require-change
DEVELOPER_BOOTSTRAP_ENABLED=false
DEVELOPER_USERNAME=developer
DEVELOPER_PASSWORD=leave-empty-unless-developer-bootstrap-enabled
DEVELOPER_FULL_NAME=Developer SchoolHub

# Required for encrypted backups. Store the real value only on the VPS env file, never in Git.
BACKUP_ENCRYPTION_PASSPHRASE=generate-long-backup-passphrase
BACKUP_DIR=/opt/schoolhub/backups
BACKUP_RETENTION_DAYS=14

API_PORT=3000
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_WINDOW_MS=600000
LOGIN_LOCK_MS=600000
WORKER_INTERVAL_MS=15000
WORKER_AUTO_MISSED_INTERVAL_MS=15000
WORKER_RECONCILE_INTERVAL_MS=30000

# For host-Caddy TLS topology, deploy with USE_VPS_TOPOLOGY=true so docker-compose.vps.yml
# binds the Docker reverse proxy to 127.0.0.1:8080.
