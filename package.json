{
  "name": "schoolhub-production",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:seed": "ts-node prisma/seed.ts",
    "build:all": "npm run build --prefix apps/api && npm run build --prefix apps/web",
    "lint:all": "npm run lint --prefix apps/api && npm run lint --prefix apps/web",
    "typecheck:all": "npm run typecheck --prefix apps/api && npm run typecheck --prefix apps/web",
    "security:audit": "npm audit --audit-level=high",
    "uat:smoke": "bash scripts/uat_smoke.sh",
    "test:backend-contract": "node scripts/backend_contract_tests.mjs",
    "test:perf-smoke": "node scripts/perf_smoke.mjs",
    "test:api": "npm run test --prefix apps/api",
    "test:web": "npm run test --prefix apps/web",
    "test:e2e": "npm run test:e2e --prefix apps/web",
    "audit:verify-chain": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/verify_audit_chain.ts",
    "validate:final": "bash scripts/validate_final.sh"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "ts-node": "10.9.2",
    "typescript": "5.7.3"
  }
}
