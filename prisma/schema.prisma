generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN_TU
  KEPALA_SEKOLAH
  GURU_MAPEL
  GURU_PIKET
  SISWA
  OPERATOR_IT
  DEVELOPER
}

enum SessionStatus {
  SCHEDULED
  OPEN
  CLOSED
  MISSED
}

enum AndroidApkVerificationStatus {
  UNVERIFIED
  VERIFIED
  REJECTED
}

enum StudentAttendanceStatus {
  HADIR
  TELAT
  IZIN
  SAKIT
  ALPA
}

enum AttendanceReviewState {
  DEFAULTED
  CONFIRMED
  CORRECTED
}

enum AuditChainEpochStatus {
  TRUSTED
  ACTIVE_TRUSTED
}

enum AuditIntegrityIncidentStatus {
  HISTORICAL_UNTRUSTED
}

enum AuditIntegrityIncidentReasonCode {
  HISTORICAL_CHAIN_INTEGRITY_LOSS
}

enum AttendanceConfirmationSource {
  MANUAL_SINGLE
  MANUAL_BULK
  FINALIZED_DEFAULT
  CORRECTION
  SYSTEM_BACKFILL
}

enum RosterCaptureSource {
  GENERATED
  OPENED
  BACKFILL
}

enum SessionRosterState {
  PENDING
  VERIFIED
  BACKFILLED_UNVERIFIED
  LEGACY_ROSTER_MISSING
}

enum TeacherSessionStatus {
  HADIR
  TELAT
  EXCUSED_ABSENCE
  ALPA_MENGAJAR
}

enum CardStatus {
  ACTIVE
  LOST
  INACTIVE
}

enum GateDirection {
  IN
  OUT
}

enum ReaderType {
  GATE
  MUSHOLA
  CLASS
  MANUAL
  QR_ANDROID
}

enum PrayerType {
  DHUHA
  DZUHUR
  ASHAR
}

enum ReconciliationFlagType {
  BOLOS_KELAS
  LUPA_TAP_GERBANG
  TIDAK_MENGAJAR
  ANOMALI_BUKA_TANPA_GERBANG
  BELUM_SCAN_GERBANG
  BELUM_SCAN_DHUHA
  BELUM_SCAN_DZUHUR
  BELUM_SCAN_ASHAR
  BELUM_SCAN_KELUAR_GERBANG
  ALPA
  OUT_TANPA_IN
  IN_BERULANG
  OUT_BERULANG
  SCAN_DUPLIKAT
  OUT_TERLALU_CEPAT
  GATE_IN_TANPA_PRESENSI
  PRESENSI_DI_LUAR_ROSTER
  HADIR_VIA_OVERRIDE
  KOREKSI_BERULANG
  OVERRIDE_BERLEBIHAN
  READER_ANOMALY
  POLICY_CHANGED_DURING_ATTENDANCE
  EXPORT_TIDAK_WAJAR
}

enum ReconciliationStatus {
  OPEN
  RESOLVED
}

enum EscalationStatus {
  QUEUED
  CLOSED
}

enum DeviceReaderStatus {
  ACTIVE
  INACTIVE
  REVOKED
}

enum QrCredentialStatus {
  ACTIVE
  REVOKED
  LOST
  EXPIRED
}

enum DevicePlatform {
  ANDROID
  HARDWARE
  WEB
}

enum AndroidReaderMode {
  GERBANG
  GATE_IN
  GATE_OUT
  MUSHOLA
  CHECK_ONLY
}

enum TeacherLeaveType {
  IZIN
  SAKIT
  DINAS_LUAR
}

enum TeacherLeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ReconciliationReviewStatus {
  OPEN
  IN_REVIEW
  ESCALATED
  RESOLVED
}

enum ReconciliationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationType {
  SESSION_MISSED
  ANOMALY_NEW
  LEAVE_SUBMITTED
  LEAVE_APPROVED
  LEAVE_REJECTED
  IMPORT_DONE
  SYSTEM
}

enum AttendanceOverrideScope {
  CLASS_ELIGIBILITY
  ASHAR_CHECKOUT
  GATE_IN
  GATE_OUT
  ALL
}

enum OverrideApprovalStatus {
  APPROVED
  PENDING_REVIEW
  REJECTED
  REVOKED
  EXPIRED
}

model User {
  id                 String     @id @default(cuid())
  username           String     @unique
  fullName           String
  nis                String?    @unique
  nkd                String?    @unique
  nip                String?
  birthDate          DateTime?  @db.Date
  passwordHash       String
  role               Role
  active             Boolean    @default(true)
  cardStatus         CardStatus @default(ACTIVE)
  sessionVersion     Int        @default(1)
  passwordChangedAt  DateTime?
  mustChangePassword Boolean    @default(false)
  archivedAt         DateTime?
  archivedById       String?
  archiveReason      String?
  deleteMode         String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  taughtSessions                        Session[]                      @relation("TeacherSessions")
  substitutionSourceSessions            Session[]                      @relation("SessionSubstitutionSourceTeacher")
  teachingAssignments                   TeachingAssignment[]
  enrollments                           ClassEnrollment[]
  createdClassEnrollments               ClassEnrollment[]              @relation("ClassEnrollmentCreatedBy")
  endedClassEnrollments                 ClassEnrollment[]              @relation("ClassEnrollmentEndedBy")
  administrativeChangedClassEnrollments ClassEnrollment[]              @relation("ClassEnrollmentAdministrativeStatusChangedBy")
  sessionRosters                        SessionRoster[]                @relation("SessionRosterStudent")
  gateLogs                              GateLog[]
  studentAttendances                    StudentAttendance[]            @relation("StudentAttendanceUser")
  correctedStudentAttendances           StudentAttendance[]            @relation("StudentAttendanceCorrectedBy")
  confirmedStudentAttendances           StudentAttendance[]            @relation("StudentAttendanceConfirmedBy")
  teacherPresences                      TeacherSessionPresence[]
  reconciliationFlags                   ReconciliationFlag[]           @relation("FlaggedUser")
  resolvedFlags                         ReconciliationFlag[]           @relation("ResolvedByUser")
  createdEscalations                    ReconciliationEscalation[]     @relation("EscalationCreatedByUser")
  closedEscalations                     ReconciliationEscalation[]     @relation("EscalationClosedByUser")
  createdPicketNotes                    PicketNote[]                   @relation("PicketNoteCreatedBy")
  updatedPicketNotes                    PicketNote[]                   @relation("PicketNoteUpdatedBy")
  audits                                AuditEntry[]                   @relation("AuditActor")
  smartCard                             SmartCard?
  nkdRegistry                           StudentNkdRegistry?
  qrCredentials                         QrCredential[]                 @relation("QrCredentialUser")
  createdQrCredentials                  QrCredential[]                 @relation("QrCredentialCreatedBy")
  revokedQrCredentials                  QrCredential[]                 @relation("QrCredentialRevokedBy")
  createdDeviceReaders                  DeviceReader[]                 @relation("DeviceReaderCreatedBy")
  updatedDeviceReaders                  DeviceReader[]                 @relation("DeviceReaderUpdatedBy")
  revokedDeviceReaders                  DeviceReader[]                 @relation("DeviceReaderRevokedBy")
  assignedFlags                         ReconciliationFlag[]           @relation("FlagAssignedToUser")
  teacherLeaves                         TeacherLeave[]                 @relation("TeacherLeaveTeacher")
  reviewedTeacherLeaves                 TeacherLeave[]                 @relation("TeacherLeaveReviewedBy")
  substituteSessions                    TeacherLeave[]                 @relation("TeacherLeaveSubstitute")
  weeklySchedules                       WeeklySchedule[]
  notifications                         Notification[]
  prayerAttendances                     PrayerAttendanceLog[]          @relation("PrayerAttendanceStudent")
  createdPrayerLogs                     PrayerAttendanceLog[]          @relation("PrayerAttendanceCreatedBy")
  attendanceOverrides                   AttendanceOverride[]           @relation("AttendanceOverrideStudent")
  createdAttendanceOverrides            AttendanceOverride[]           @relation("AttendanceOverrideCreatedBy")
  approvedAttendanceOverrides           AttendanceOverride[]           @relation("AttendanceOverrideApprovedBy")
  revokedAttendanceOverrides            AttendanceOverride[]           @relation("AttendanceOverrideRevokedBy")
  correctionEventsAsStudent             AttendanceCorrectionEvent[]    @relation("CorrectionStudent")
  correctionEventsAsActor               AttendanceCorrectionEvent[]    @relation("CorrectionActor")
  authSessions                          AuthSession[]
  tutorialState                         UserTutorialState?             @relation("TutorialStateUser")
  forcedTutorials                       UserTutorialState[]            @relation("TutorialForcedBy")
  createdAndroidApkReleases             AndroidApkRelease[]            @relation("AndroidApkReleaseCreatedBy")
  updatedAndroidApkReleases             AndroidApkRelease[]            @relation("AndroidApkReleaseUpdatedBy")
  archivedBy                            User?                          @relation("UserArchivedBy", fields: [archivedById], references: [id], onDelete: SetNull)
  archivedUsers                         User[]                         @relation("UserArchivedBy")
  updatedAccountDeleteSecuritySettings  AccountDeleteSecuritySetting[] @relation("AccountDeletePinUpdatedBy")

  @@index([role, active])
  @@index([active, createdAt])
  @@index([active, archivedAt, createdAt])
  @@index([archivedAt])
  @@index([archivedById, archivedAt])
}

model SchoolClass {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  yearLabel String
  createdAt DateTime @default(now())

  enrollments         ClassEnrollment[]
  sessions            Session[]
  weeklySchedules     WeeklySchedule[]
  teachingAssignments TeachingAssignment[]
  reconciliationFlags ReconciliationFlag[]

  @@index([yearLabel])
}

model Subject {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())

  sessions            Session[]
  weeklySchedules     WeeklySchedule[]
  teachingAssignments TeachingAssignment[]
}

model AcademicYear {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  startsAt  DateTime?
  endsAt    DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  semesters           Semester[]
  weeklySchedules     WeeklySchedule[]
  teachingAssignments TeachingAssignment[]
  classEnrollments    ClassEnrollment[]
}

model Semester {
  id             String    @id @default(cuid())
  academicYearId String
  code           String
  name           String
  startsAt       DateTime?
  endsAt         DateTime?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  academicYear        AcademicYear         @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  weeklySchedules     WeeklySchedule[]
  teachingAssignments TeachingAssignment[]
  classEnrollments    ClassEnrollment[]

  @@unique([academicYearId, code])
  @@index([active])
}

model Room {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weeklySchedules WeeklySchedule[]
  sessions        Session[]
}

model ClassEnrollment {
  id                              String    @id @default(cuid())
  classId                         String
  studentId                       String
  academicYearId                  String?
  semesterId                      String?
  effectiveFrom                   DateTime  @db.Date
  effectiveTo                     DateTime? @db.Date
  active                          Boolean   @default(true)
  administrativeStatus            String    @default("ACTIVE")
  administrativeStatusChangedAt   DateTime?
  administrativeStatusChangedById String?
  administrativeStatusReason      String?
  createdById                     String?
  endedById                       String?
  endedReason                     String?
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt

  schoolClass                   SchoolClass     @relation(fields: [classId], references: [id], onDelete: Cascade)
  student                       User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear                  AcademicYear?   @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  semester                      Semester?       @relation(fields: [semesterId], references: [id], onDelete: Restrict)
  administrativeStatusChangedBy User?           @relation("ClassEnrollmentAdministrativeStatusChangedBy", fields: [administrativeStatusChangedById], references: [id], onDelete: SetNull)
  createdBy                     User?           @relation("ClassEnrollmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  endedBy                       User?           @relation("ClassEnrollmentEndedBy", fields: [endedById], references: [id], onDelete: SetNull)
  rosters                       SessionRoster[]

  @@index([studentId, administrativeStatus, effectiveFrom, effectiveTo])
  @@index([classId, administrativeStatus, effectiveFrom, effectiveTo])
  @@index([academicYearId])
  @@index([semesterId])
}

model Session {
  id                   String        @id @default(cuid())
  classId              String
  subjectId            String
  teacherId            String
  startsAt             DateTime
  endsAt               DateTime
  businessDate         DateTime      @db.Date
  status               SessionStatus     @default(SCHEDULED)
  rosterState          SessionRosterState @default(PENDING)
  openedAt             DateTime?
  closedAt             DateTime?
  reconciledAt         DateTime?
  weeklyScheduleId     String?
  teachingAssignmentId           String?
  substitutionSourceTeacherId    String?
  substitutionSourceAssignmentId String?
  roomId                         String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  schoolClass        SchoolClass         @relation(fields: [classId], references: [id], onDelete: Restrict)
  subject            Subject             @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  teacher            User                @relation("TeacherSessions", fields: [teacherId], references: [id], onDelete: Restrict)
  weeklySchedule     WeeklySchedule?     @relation(fields: [weeklyScheduleId], references: [id], onDelete: SetNull)
  teachingAssignment           TeachingAssignment? @relation("SessionActingTeachingAssignment", fields: [teachingAssignmentId], references: [id], onDelete: Restrict)
  substitutionSourceTeacher    User?                @relation("SessionSubstitutionSourceTeacher", fields: [substitutionSourceTeacherId], references: [id], onDelete: Restrict)
  substitutionSourceAssignment TeachingAssignment?  @relation("SessionSubstitutionSourceAssignment", fields: [substitutionSourceAssignmentId], references: [id], onDelete: Restrict)
  room                         Room?                @relation(fields: [roomId], references: [id], onDelete: SetNull)
  attendances        StudentAttendance[]
  teacherPresence    TeacherSessionPresence[]
  flags              ReconciliationFlag[]
  correctionEvents   AttendanceCorrectionEvent[]
  rosters            SessionRoster[]

  @@index([startsAt])
  @@index([businessDate])
  @@index([status])
  @@index([status, startsAt])
  @@index([rosterState, status, reconciledAt])
  @@index([classId, startsAt])
  @@index([teacherId, startsAt])
  @@index([roomId, startsAt])
  @@index([weeklyScheduleId, startsAt])
  @@index([teachingAssignmentId, startsAt], map: "Session_teachingAssignmentId_startsAt_idx")
  @@index([substitutionSourceTeacherId, businessDate], map: "Session_substitutionSourceTeacherId_businessDate_idx")
  @@index([substitutionSourceAssignmentId, startsAt], map: "Session_substitutionSourceAssignmentId_startsAt_idx")
}

model StudentAttendance {
  id                 String                        @id @default(cuid())
  sessionId          String
  studentId          String
  status             StudentAttendanceStatus
  note               String?
  evidenceLabel      String                        @default("normal")
  usedOverrideId     String?
  correctionCount    Int                           @default(0)
  correctedAt        DateTime?
  correctedById      String?
  reviewState        AttendanceReviewState         @default(DEFAULTED)
  confirmedAt        DateTime?
  confirmedById      String?
  confirmationSource AttendanceConfirmationSource?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  session          Session                     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student          User                        @relation("StudentAttendanceUser", fields: [studentId], references: [id], onDelete: Cascade)
  roster           SessionRoster               @relation("AttendanceRosterMembership", fields: [sessionId, studentId], references: [sessionId, studentId], onDelete: Cascade)
  usedOverride     AttendanceOverride?         @relation("AttendanceUsedOverride", fields: [usedOverrideId], references: [id], onDelete: SetNull)
  correctedBy      User?                       @relation("StudentAttendanceCorrectedBy", fields: [correctedById], references: [id], onDelete: SetNull)
  confirmedBy      User?                       @relation("StudentAttendanceConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)
  correctionEvents AttendanceCorrectionEvent[]

  @@unique([sessionId, studentId])
  @@index([status])
  @@index([studentId, status])
  @@index([studentId, updatedAt])
  @@index([usedOverrideId])
  @@index([evidenceLabel])
  @@index([reviewState])
  @@index([confirmedById])
}

model SessionRoster {
  id                       String              @id @default(cuid())
  sessionId                String
  studentId                String
  enrollmentId             String?
  studentNameSnapshot      String
  studentUsernameSnapshot  String
  classIdSnapshot          String
  classCodeSnapshot        String
  classNameSnapshot        String
  academicYearIdSnapshot   String?
  academicYearNameSnapshot String?
  semesterIdSnapshot       String?
  semesterNameSnapshot     String?
  capturedAt               DateTime            @default(now())
  captureSource            RosterCaptureSource
  activeAtCapture          Boolean             @default(true)
  metadata                 Json?

  session    Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student    User               @relation("SessionRosterStudent", fields: [studentId], references: [id], onDelete: Restrict)
  enrollment ClassEnrollment?   @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  attendance StudentAttendance? @relation("AttendanceRosterMembership")

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@index([enrollmentId])
  @@index([classIdSnapshot])
  @@index([captureSource])
}

model TeacherSessionPresence {
  id                  String               @id @default(cuid())
  sessionId           String
  teacherId           String
  status              TeacherSessionStatus
  checkInAt           DateTime?
  checkOutAt          DateTime?
  checkInLat          Float?
  checkInLng          Float?
  checkOutLat         Float?
  checkOutLng         Float?
  checkInById         String?
  checkOutById        String?
  earlyCheckoutReason String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  teacher User    @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([sessionId, teacherId])
  @@index([checkInAt])
  @@index([checkOutAt])
  @@index([teacherId, checkInAt])
}

model GateLog {
  id                String             @id @default(cuid())
  userId            String
  direction         GateDirection
  businessDate      DateTime           @db.Date
  tappedAt          DateTime           @default(now())
  deviceId          String?
  readerId          String?
  cardId            String?
  qrCredentialId    String?
  scanMode          AndroidReaderMode?
  appVersion        String?
  signatureVerified Boolean            @default(false)
  serverReceivedAt  DateTime           @default(now())
  deviceEventId     String?            @unique
  deviceTimestamp   DateTime?
  nonceHash         String?
  bodyHash          String?
  manualReason      String?
  createdById       String?
  usedOverrideId    String?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrCredential QrCredential? @relation(fields: [qrCredentialId], references: [id], onDelete: SetNull)

  @@unique([userId, businessDate, direction], map: "GateLog_userId_businessDate_direction_key")
  @@index([tappedAt])
  @@index([businessDate])
  @@index([userId, tappedAt])
  @@index([userId, direction, tappedAt])
  @@index([deviceId, tappedAt])
  @@index([readerId, tappedAt])
  @@index([qrCredentialId, tappedAt])
  @@index([scanMode, tappedAt])
  @@index([signatureVerified, tappedAt])
  @@index([deviceEventId])
}

model GateLogDeduplication {
  id                 String        @id
  duplicateGateLogId String
  canonicalGateLogId String
  userId             String
  businessDate       DateTime      @db.Date
  direction          GateDirection
  decision           String
  createdAt          DateTime      @default(now())

  @@index([userId, businessDate, direction])
  @@index([canonicalGateLogId])
}

model GateLogArchive {
  id                    String             @id @default(cuid())
  originalGateLogId     String             @unique
  canonicalGateLogId    String
  userId                String
  direction             GateDirection
  originalBusinessDate  DateTime?          @db.Date
  correctedBusinessDate DateTime           @db.Date
  tappedAt              DateTime
  serverReceivedAt      DateTime?
  deviceId              String?
  readerId              String?
  cardId                String?
  qrCredentialId        String?
  scanMode              AndroidReaderMode?
  appVersion            String?
  signatureVerified     Boolean?
  deviceEventId         String?
  deviceTimestamp       DateTime?
  nonceHash             String?
  bodyHash              String?
  manualReason          String?
  createdById           String?
  usedOverrideId        String?
  completeOriginalRow   Json
  dedupeReason          String
  migrationVersion      String
  archivedAt            DateTime           @default(now())

  @@index([userId, correctedBusinessDate, direction])
  @@index([canonicalGateLogId])
  @@index([archivedAt])
}

model BusinessDateBackfillReport {
  id                    String    @id
  migrationVersion      String
  sourceTable           String
  rowId                 String
  observedTimestamp     DateTime
  currentBusinessDate   DateTime? @db.Date
  correctedBusinessDate DateTime  @db.Date
  dateChanged           Boolean
  duplicateGroupBefore  Json
  duplicateGroupAfter   Json
  createdAt             DateTime  @default(now())

  @@unique([migrationVersion, sourceTable, rowId])
  @@index([sourceTable, dateChanged])
  @@index([migrationVersion])
}

model RejectedDeviceScan {
  id               String             @id @default(cuid())
  eventId          String?
  cardUid          String?
  direction        GateDirection?
  deviceTimestamp  DateTime?
  serverReceivedAt DateTime           @default(now())
  readerId         String?
  deviceId         String?
  scanMode         AndroidReaderMode?
  nonceHash        String?
  bodyHash         String?
  reason           String
  createdAt        DateTime           @default(now())

  reader DeviceReader? @relation(fields: [readerId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([readerId, createdAt])
  @@index([scanMode, createdAt])
  @@index([createdAt])
}

model ReconciliationFlag {
  id             String                     @id @default(cuid())
  type           ReconciliationFlagType
  status         ReconciliationStatus       @default(OPEN)
  sessionId      String?
  userId         String
  details        Json?
  createdAt      DateTime                   @default(now())
  resolvedAt     DateTime?
  resolvedReason String?
  resolvedById   String?
  reviewStatus   ReconciliationReviewStatus @default(OPEN)
  priority       ReconciliationPriority     @default(NORMAL)
  assignedToId   String?
  followUpNote   String?
  dueAt          DateTime?

  classId        String?
  evidence       Json?
  recommendation String?
  fingerprint    String?

  session     Session?                   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  schoolClass SchoolClass?               @relation(fields: [classId], references: [id], onDelete: SetNull)
  user        User                       @relation("FlaggedUser", fields: [userId], references: [id], onDelete: Cascade)
  resolvedBy  User?                      @relation("ResolvedByUser", fields: [resolvedById], references: [id], onDelete: SetNull)
  assignedTo  User?                      @relation("FlagAssignedToUser", fields: [assignedToId], references: [id], onDelete: SetNull)
  escalations ReconciliationEscalation[]

  @@unique([type, sessionId, userId])
  @@unique([fingerprint])
  @@index([status])
  @@index([type])
  @@index([reviewStatus])
  @@index([priority])
  @@index([assignedToId])
  @@index([status, createdAt])
  @@index([reviewStatus, priority, createdAt])
  @@index([userId, status])
  @@index([classId, status])
  @@index([status, priority, type, createdAt])
  @@index([dueAt])
}

model ReconciliationEscalation {
  id          String           @id @default(cuid())
  flagId      String
  status      EscalationStatus @default(QUEUED)
  reason      String
  createdById String
  closedById  String?
  createdAt   DateTime         @default(now())
  closedAt    DateTime?

  flag      ReconciliationFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)
  createdBy User               @relation("EscalationCreatedByUser", fields: [createdById], references: [id], onDelete: Restrict)
  closedBy  User?              @relation("EscalationClosedByUser", fields: [closedById], references: [id], onDelete: SetNull)

  @@index([flagId, status])
  @@index([createdAt])
}

model AuthSession {
  id               String    @id @default(cuid())
  userId           String
  sessionVersion   Int       @default(1)
  refreshTokenHash String?
  tokenFamilyId    String?
  userAgent        String?
  requestIp        String?
  createdIp        String?
  lastIp           String?
  issuedAt         DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastSeenAt       DateTime?
  lastUsedAt       DateTime?
  expiresAt        DateTime
  revokedAt        DateTime?
  revokedReason    String?
  replacedById     String?

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy AuthSession?  @relation("SessionRotation", fields: [replacedById], references: [id], onDelete: SetNull)
  replaces   AuthSession[] @relation("SessionRotation")

  @@index([userId, revokedAt, expiresAt])
  @@index([refreshTokenHash])
  @@index([tokenFamilyId, revokedAt])
  @@index([createdAt])
}

model UserTutorialState {
  id              String    @id @default(cuid())
  userId          String    @unique
  tutorialVersion String    @default("2026.04")
  completedAt     DateTime?
  dismissedAt     DateTime?
  forceShowAt     DateTime?
  forceShowById   String?
  lastSeenAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user        User  @relation("TutorialStateUser", fields: [userId], references: [id], onDelete: Cascade)
  forceShowBy User? @relation("TutorialForcedBy", fields: [forceShowById], references: [id], onDelete: SetNull)

  @@index([tutorialVersion, completedAt])
  @@index([forceShowAt])
  @@index([forceShowById])
}

model AuditEntry {
  id               String   @id @default(cuid())
  sequence         BigInt   @unique
  actorId          String?
  actorRole        Role?
  action           String
  module           String?
  resource         String
  resourceId       String
  reason           String?
  requestIp        String?
  requestDevice    String?
  before           Json?
  after            Json?
  canonicalPayload Json?
  prevHash         String?
  entryHash        String?
  hashVersion      Int      @default(1)
  createdAt        DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([actorId, action, createdAt])
  @@index([module, createdAt])
  @@index([action, createdAt])
  @@index([resource, resourceId])
  @@index([requestIp, createdAt])
  @@index([entryHash])
}

model OutboxEvent {
