NODE_ENV=production

# ============================================================
# SUPABASE DATABASE (PostgreSQL)
# ============================================================
# 1. Buka https://supabase.com → buat project baru
# 2. Settings → Database → Connection String → URI
# 3. Ganti [password] dengan password yang kamu buat saat create project
# 4. Format pooling (port 6543) untuk app runtime:
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
# 5. Format direct (port 5432) untuk Prisma migrate:
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ============================================================
# REDIS (optional, bisa dihapus kalau tidak perlu cache)
# ============================================================
# Kalau mau pakai Redis, install di VPS atau pakai Upstash:
# REDIS_URL=redis://localhost:6379
# Kalau tidak pakai Redis, comment baris di atas.

# ============================================================
# JWT & SESSION
# ============================================================
JWT_SECRET=generate-with-openssl-rand-base64-64
JWT_ISSUER=schoolhub-ehadir
JWT_AUDIENCE=schoolhub-web
JWT_EXPIRES_IN=15m
SESSION_TTL_MS=28800000
REFRESH_TTL_MS=604800000

# ============================================================
# WORKER TOKEN (shared secret antara worker dan API)
# ============================================================
WORKER_TOKEN=generate-with-openssl-rand-base64-48

# ============================================================
# CARD READER (opsional, kalau pakai HP scanner)
# ============================================================
READER_SECRET_ENCRYPTION_KEY=generate-with-openssl-rand-base64-48
READER_SIGNATURE_SKEW_MS=120000
READER_NONCE_TTL_MS=300000

# ============================================================
# CORS (WAJIB diisi dengan URL Vercel kamu)
# ============================================================
# Format: https://nama-project.vercel.app
# Kalau pakai custom domain: https://ehadir.sch.id
# Bisa multiple, pisahkan dengan koma:
CORS_ORIGIN=https://schoolhub-ehadir.vercel.app

# SSO / WorkOS AuthKit (disabled by default; enable only after backend mapping is configured)
SSO_ENABLED=false
WORKOS_CLIENT_ID=
WORKOS_CLIENT_SECRET=
WORKOS_ISSUER=
WORKOS_AUDIENCE=
WORKOS_REDIRECT_URI=
PUBLIC_APP_ORIGIN=https://schoolhub-ehadir.vercel.app

# ============================================================
# SECURITY
# ============================================================
STEP_UP_FOR_POLICY=true
STEP_UP_FOR_READER_ROTATE=true
MIN_GATE_STAY_MINUTES=10
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_WINDOW_MS=600000
LOGIN_LOCK_MS=600000

# ============================================================
# ADMIN DEFAULT ACCOUNT
# ============================================================
ADMIN_USERNAME=admin.tu
ADMIN_PASSWORD=generate-unique-bootstrap-password-do-not-reuse
ADMIN_FULL_NAME=Admin TU
DEFAULT_USER_PASSWORD=generate-unique-temporary-password-require-change

# ============================================================
# DEVELOPER ACCOUNT
# ============================================================
DEVELOPER_USERNAME=developer
DEVELOPER_PASSWORD=generate-unique-developer-password-do-not-reuse
DEVELOPER_FULL_NAME=Developer SchoolHub

# ============================================================
# API PORT (untuk internal Docker, jangan diubah)
# ============================================================
API_PORT=3000

# ============================================================
# WORKER INTERVALS
# ============================================================
WORKER_INTERVAL_MS=15000
WORKER_AUTO_MISSED_INTERVAL_MS=15000
WORKER_RECONCILE_INTERVAL_MS=30000

# ============================================================
# ANDROID READER VERSION (opsional)
# ============================================================
ANDROID_READER_MIN_SUPPORTED_VERSION_CODE=1
ANDROID_READER_LATEST_VERSION_NAME=1.0.0
ANDROID_READER_LATEST_VERSION_CODE=1
