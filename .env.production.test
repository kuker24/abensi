NODE_ENV=production
POSTGRES_DB=schoolhub
POSTGRES_USER=schoolhub
POSTGRES_PASSWORD=ci-compose-password-not-for-production
DATABASE_URL=postgresql://schoolhub:ci-compose-password-not-for-production@postgres:5432/schoolhub?schema=public
DIRECT_URL=postgresql://schoolhub:ci-compose-password-not-for-production@postgres:5432/schoolhub?schema=public
REDIS_URL=redis://redis:6379
JWT_SECRET=ci-only-random-looking-secret-value-with-more-than-forty-eight-characters
JWT_ISSUER=schoolhub-ci
JWT_AUDIENCE=schoolhub-web-ci
JWT_EXPIRES_IN=15m
SESSION_TTL_MS=28800000
REFRESH_TTL_MS=604800000
WORKER_TOKEN=ci-worker-token-with-more-than-thirty-two-characters
READER_SECRET_ENCRYPTION_KEY=ci-reader-secret-with-more-than-thirty-two-characters
CORS_ORIGIN=https://example.invalid
PUBLIC_APP_ORIGIN=https://example.invalid
WORKER_INTERVAL_MS=15000
WORKER_RECONCILE_INTERVAL_MS=30000
WORKER_AUTO_MISSED_INTERVAL_MS=15000
SCHOOL_TIMEZONE=Asia/Jakarta
TRUSTED_PROXY_CIDRS=loopback,linklocal,uniquelocal
SSO_ENABLED=false
STEP_UP_FOR_POLICY=true
STEP_UP_FOR_READER_ROTATE=true
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_USERNAME=admin.tu
ADMIN_PASSWORD=TataUsaha#2026Strong!
ADMIN_FULL_NAME=Admin TU
DEFAULT_USER_PASSWORD=User#12345678
DEVELOPER_BOOTSTRAP_ENABLED=false
DEVELOPER_USERNAME=developer
DEVELOPER_PASSWORD=DeveloperOps#2026Strong!
DEVELOPER_FULL_NAME=Developer SchoolHub
BACKUP_ENCRYPTION_PASSPHRASE=ci-backup-passphrase-with-more-than-thirty-two-characters
BACKUP_DIR=artifacts/local-backups
