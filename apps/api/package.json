{
  "name": "schoolhub-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "node ../../scripts/generate_api_prisma_client.mjs",
    "prisma:migrate": "prisma migrate deploy --schema ../../prisma/schema.prisma",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.19",
    "@nestjs/jwt": "11.0.0",
    "@nestjs/passport": "11.0.3",
    "@nestjs/platform-express": "11.1.27",
    "@prisma/client": "5.22.0",
    "@schoolhub/shared": "file:../../packages/shared",
    "bcryptjs": "2.4.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "helmet": "^8.2.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pdfkit": "^0.19.1",
    "prisma": "^5.22.0",
    "redis": "^4.7.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/express": "5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "22.10.2",
    "@types/passport-jwt": "4.0.1",
    "@types/pdfkit": "^0.17.6",
    "@typescript-eslint/eslint-plugin": "8.18.2",
    "@typescript-eslint/parser": "8.18.2",
    "eslint": "9.39.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "2.0.0",
    "typescript": "6.0.3"
  },
  "overrides": {
    "tmp": "0.2.7",
    "multer": "2.2.0",
    "uuid": "11.1.1",
    "js-yaml": "4.3.0"
  }
}
