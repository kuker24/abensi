#!/usr/bin/env sh
set -e
APP_HOME=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
if command -v gradle >/dev/null 2>&1; then
  exec gradle "$@"
fi
VERSION=8.7
DIST_DIR="$APP_HOME/.gradle/wrapper/dists/gradle-$VERSION"
GRADLE_BIN="$DIST_DIR/gradle-$VERSION/bin/gradle"
ZIP="$DIST_DIR/gradle-$VERSION-bin.zip"
if [ ! -x "$GRADLE_BIN" ]; then
  if ! command -v curl >/dev/null 2>&1 || ! command -v unzip >/dev/null 2>&1; then
    echo "Gradle not installed. Install gradle or provide curl+unzip so this launcher can download Gradle $VERSION." >&2
    exit 127
  fi
  mkdir -p "$DIST_DIR"
  if [ ! -f "$ZIP" ]; then
    echo "Downloading Gradle $VERSION..." >&2
    curl -L --fail --retry 3 -o "$ZIP" "https://services.gradle.org/distributions/gradle-$VERSION-bin.zip"
  fi
  unzip -q -o "$ZIP" -d "$DIST_DIR"
fi
exec "$GRADLE_BIN" "$@"
