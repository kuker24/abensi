# ============================================================
# SIAB2 — Frontend Environment Variables
# ============================================================
# Untuk Vercel: set di Project Settings → Environment Variables
# Untuk local: copy ke .env.local dan sesuaikan
# ============================================================

# URL backend API (WAJIB diisi untuk Vercel)
# Contoh: https://absensi.man1rokanhulu.cloud/api/v1
# Contoh: https://157.15.40.21/api/v1
VITE_API_BASE_URL=/api/v1

# SSO (WorkOS AuthKit) — set to 'true' to enable SSO button on login page
# Both frontend AND backend must be configured for SSO to work.
# When disabled, only username/password login is available.
VITE_SSO_ENABLED=false
